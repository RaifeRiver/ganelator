#include <stdio.h>

void calculate_pi(int g,unsigned int*result_ptr){volatile unsigned int*L=result_ptr;volatile unsigned int*H=result_ptr+1;*H=0x30000;*L=0;int n=g*7000;if(n>1e5) n=1e5;for(int i=1;i<=n;i++){unsigned int d=i*2,m=d*(d+1)*(d+2),h=0x40000/m,r=0x40000%m,l=((unsigned long)r*0xFFFFFFFF)/m,p=*L;if(i&1){*L+=l;if(*L<p)(*H)++;*H+=h;} else{*L-=l;if(*L>p)(*H)--;*H-=h;}}}

int main() {
    unsigned int pi_data[2]; // Fixed spelling of "unsigned"
    calculate_pi(14, pi_data);

    // To print it, we convert the "high" part back to a normal decimal
    // The whole number is the top 16 bits of the high word
    unsigned int whole = pi_data[1] >> 16;
    
    // This calculates the fractional part for printing
    double decimal = (double)pi_data[1] / 65536.0 + (double)pi_data[0] / 4294967296.0 / 65536.0;

    printf("Pi is roughly: %.14f\n", decimal);
    return 0;
}
